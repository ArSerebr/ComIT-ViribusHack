# Скопируйте в `.env` в корне репозитория и подстройте значения.
# Используют: Docker Compose, локальный backend (uvicorn/alembic/seed), Vite dev.

# --- PostgreSQL (compose + локальный DSN ниже) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=comit
POSTGRES_PORT=5432

# --- Backend (локально без Docker: localhost; в контейнере задаёт compose) ---
# Один и тот же DSN используют FastAPI и Django admin-panel (см. admin-panel/admin_panel/settings.py).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/comit
SQLALCHEMY_ECHO=false

# --- Redis (сессии access-токена; uvicorn/ pytest на хосте — localhost; в docker-compose для backend URL задаётся в compose, не отсюда) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth (fastapi-users: JWT + reset/verify; reset/verify по умолчанию = JWT_SECRET) ---
JWT_SECRET=change-me-in-production
JWT_LIFETIME_SECONDS=3600
# RESET_PASSWORD_TOKEN_SECRET=
# VERIFICATION_TOKEN_SECRET=
BACKEND_PUBLISH_PORT=8000

# --- Frontend (только Vite dev; в Docker nginx берёт BACKEND_HOST из compose) ---
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
# Прокси /qmsg → QmsgCore (Vite dev; в Docker nginx проксирует на qmsg-core:8090)
VITE_QMSG_PROXY_TARGET=http://127.0.0.1:8090
# Прод с API на поддомене (пример: deploy/README-comit.md). Без слэша в конце. Задать ДО сборки фронта.
# VITE_API_BASE_URL=https://api.comit.robofirst.ru
# Если HTTPS только на нестандартном порту (например 7009): https://api.comit.robofirst.ru:7009
# Пусто = относительные /api (один домен, прокси через контейнер frontend).
# При `false` не подставлять демо-данные из `src/data` при ошибках API (по умолчанию — подставлять).
# VITE_API_STATIC_FALLBACK=false

# --- Docker: nginx → backend в сети compose ---
BACKEND_HOST=backend
BACKEND_UPSTREAM_PORT=8000
FRONTEND_PORT=8080
FRONTEND_DEV_PORT=5173
ADMIN_PANEL_PORT=8010

# --- PulseCore (AI-чат), QmsgCore (групповой чат), ML ---
MONGO_PORT=27017
PULSE_CORE_PORT=8091
QMSG_CORE_PORT=8090
# URL QmsgCore для backend (Docker: http://qmsg-core:8090, локально: http://localhost:8090)
QMSG_CORE_BASE_URL=http://localhost:8090
# GC_PULSE_BASE_URL для QmsgCore задаётся в compose (http://pulse-core:8091)
# GIGACHAT_AUTH_KEY для ML (опционально)
# GIGACHAT_AUTH_KEY=

# --- Django admin-panel ---
# Если задан DATABASE_URL выше — Django берёт хост/БД из него (как backend).
# Иначе: POSTGRES_*; для локального manage.py без DATABASE_URL задайте POSTGRES_HOST=localhost.
DJANGO_SECRET_KEY=change-me-admin-secret
DJANGO_DEBUG=false
# Comma-separated values, e.g. localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=*
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin12345
# Gunicorn workers (admin-panel entrypoint); по умолчанию 2
# ADMIN_PANEL_WEB_CONCURRENCY=2

# --- Опционально: тестовый admin при seed (scripts/seed_db, старт backend в Docker) ---
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=

# --- Docker backend: при старте — alembic + seed + uvicorn. Раскомментируйте, чтобы не грузить seed ---
# SKIP_SEED=1

# --- OpenAPI: при старте uvicorn backend перезаписывает openapi/openapi.yaml (в монорепо — каталог ../openapi). ---
# SKIP_OPENAPI_EXPORT=1
# OPENAPI_YAML_PATH=C:/path/to/openapi.yaml
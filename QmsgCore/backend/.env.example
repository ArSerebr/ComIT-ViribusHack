# Copy this file to .env and fill in your values.

# PostgreSQL password
POSTGRES_PASSWORD=change_me_strong_password

# JWT secret — used to sign tokens issued by /v1/auth/token
JWT_SECRET=change_me_long_random_secret

# Host port for the Group Chat service
GROUPCHAT_PORT=18090

# PulseAI base URL (default points to the cloud instance)
PULSE_BASE_URL=http://chat.droidje-cloud.ru
